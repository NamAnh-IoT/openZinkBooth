<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer glow halo – extended to r=54 to fill the full canvas so no
         background color bleeds through at the edges on the system launcher -->
    <path android:fillColor="#2EFFFFFF"
        android:pathData="M54,0 A54,54 0 1,1 53.99,0 Z"/>

    <!-- Inner glow around ring: r=34 -->
    <path android:fillColor="#28FFFFFF"
        android:pathData="M54,20 A34,34 0 1,1 53.99,20 Z"/>

    <!-- Main ring: r=22, strokeWidth=12 -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="12"
        android:pathData="M54,32 A22,22 0 1,1 53.99,32 Z"/>

    <!-- Center dot: r=7 -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M54,47 A7,7 0 1,1 53.99,47 Z"/>

</vector>